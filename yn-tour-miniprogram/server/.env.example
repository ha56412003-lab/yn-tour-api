# 服务器配置
PORT=3000
NODE_ENV=development

# MongoDB 连接
MONGODB_URI=mongodb://localhost:27017/yn-tour

# 微信支付配置
WECHAT_APPID=your_wechat_appid
WECHAT_MCHID=your_wechat_mchid
WECHAT_API_KEY=your_wechat_api_key
WECHAT_CERT_PATH=/path/to/cert

# 支付宝配置
ALIPAY_APPID=your_alipay_appid
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key

# 微信小程序配置
MINIPROGRAM_APPID=your_miniprogram_appid
MINIPROGRAM_SECRET=your_miniprogram_secret

